<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:resources="clr-namespace:CloudlogHelper.Resources"
        xmlns:viewModels="clr-namespace:CloudlogHelper.ViewModels"
        xmlns:stepVm="clr-namespace:CloudlogHelper.ViewModels.WizardSteps"
        xmlns:stepViews="clr-namespace:CloudlogHelper.Views.WizardSteps"
        mc:Ignorable="d"
        d:DesignWidth="900"
        d:DesignHeight="700"
        x:Class="CloudlogHelper.Views.WizardWindow"
        x:DataType="viewModels:WizardWindowViewModel"
        Title="{I18N {x:Static resources:LangKeys.WizardTitle}}"
        Width="900"
        Height="700"
        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        FontFamily="Segoe UI"
        Icon="avares://CloudlogHelper/Assets/icon.png">

    <Window.Styles>
        <!-- 侧边栏卡片 -->
        <Style Selector="Border.sidebar-card">
            <Setter Property="Background" Value="{DynamicResource SystemChromeLowColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundChromeDisabledLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <!-- 内容卡片 -->
        <Style Selector="Border.content-card">
            <Setter Property="Background" Value="{DynamicResource SystemChromeLowColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundChromeDisabledLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style Selector="TextBlock.action-caption">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </Style>

        <Style Selector="TextBlock.action-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <Style Selector="TextBlock.content-title">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <Style Selector="TextBlock.sidebar-title">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <!-- 步骤计数芯片 - 使用系统强调色变体 -->
        <Style Selector="Border.step-count-chip">
            <Setter Property="Background" Value="{DynamicResource SystemChromeHighColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemChromeHighColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14 7" />
        </Style>

        <Style Selector="Border.step-count-chip TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <Style Selector="Border.page-card">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundChromeDisabledLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <Style Selector="TextBlock.page-hint">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0 0 0 4" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <Style Selector="TextBox.input, ComboBox.input">
            <Setter Property="MinWidth" Value="300" />
        </Style>

        <!-- 主要导航按钮 - 使用系统强调色 -->
        <Style Selector="Button.nav-primary">
            <Setter Property="MinWidth" Value="126" />
            <Setter Property="Padding" Value="18 10" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.nav-primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorDark1}" />
        </Style>

        <Style Selector="Button.nav-primary:pressed">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark2}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorDark2}" />
        </Style>

        <!-- 次要导航按钮 -->
        <Style Selector="Button.nav-secondary">
            <Setter Property="MinWidth" Value="126" />
            <Setter Property="Padding" Value="18 10" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.nav-secondary:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
        </Style>

        <Style Selector="Button.nav-secondary:pressed">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
        </Style>

        <!-- 页脚链接按钮 -->
        <Style Selector="Button.footer-link">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="21" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundChromeDisabledLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.footer-link:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
        </Style>

        <Style Selector="Button.footer-link:pressed">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorDark1}" />
        </Style>

        <!-- 子区域卡片 -->
        <Style Selector="Border.subsection-card">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundChromeDisabledLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
        </Style>

        <!-- 高亮卡片 -->
        <Style Selector="Border.highlight-card">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource  SystemChromeMediumLowColor}" />
        </Style>

        <!-- 警告提示 -->
        <Style Selector="Border.notice-warning">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Border.notice-warning TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </Style>

        <!-- 特性标签 -->
        <Style Selector="Border.feature-chip">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundChromeDisabledLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10 6" />
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0 0 0 8" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <Style Selector="TextBlock.subsection-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0 0 0 4" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <Style Selector="TextBlock.setting-label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0 0 12 0" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <Style Selector="ComboBox.setting-control, TextBox.setting-control">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Width" Value="250" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- 步骤导航按钮 -->
        <Style Selector="Button.step-nav">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Padding" Value="10 10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <Style Selector="Button.step-nav:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundChromeDisabledLowBrush}" />
        </Style>

        <Style Selector="Button.step-nav:pressed">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
        </Style>

        <Style Selector="Button.step-nav:disabled">
            <Setter Property="Opacity" Value="0.55" />
        </Style>

        <!-- 激活的步骤区域 -->
        <Style Selector="Border.step-nav-active">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Padding" Value="10 10" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- 步骤徽章 -->
        <Style Selector="Border.step-badge">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundChromeDisabledLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- 激活的步骤徽章 -->
        <Style Selector="Border.step-badge-active">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
        </Style>

        <Style Selector="TextBlock.step-nav-title">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </Style>

        <Style Selector="Border.step-nav-active TextBlock.step-nav-title">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>
    </Window.Styles>

    <Grid Margin="24">
        <Grid ColumnDefinitions="236,*" ColumnSpacing="20">
            <Grid RowDefinitions="Auto,*">
                <Border Classes="sidebar-card" VerticalAlignment="Top">
                    <StackPanel Spacing="8">
                        <Button Classes="step-nav"
                                IsVisible="{Binding !ShowWelcomeStep}"
                                IsEnabled="{Binding CanNavigateToWelcomeStep}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="0">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Classes="step-badge">
                                    <avalonia:MaterialIcon Kind="Info"
                                                           Width="16"
                                                           Height="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{I18N {x:Static resources:LangKeys.WizardWelcomeTitle}}"
                                           Classes="step-nav-title" />
                            </Grid>
                        </Button>
                        <Border Classes="step-nav-active" IsVisible="{Binding ShowWelcomeStep}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Classes="step-badge step-badge-active">
                                    <avalonia:MaterialIcon Kind="Info"
                                                           Width="16"
                                                           Height="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{I18N {x:Static resources:LangKeys.WizardWelcomeTitle}}"
                                           Classes="step-nav-title" />
                            </Grid>
                        </Border>

                        <Button Classes="step-nav"
                                IsVisible="{Binding !ShowBasicStep}"
                                IsEnabled="{Binding CanNavigateToBasicStep}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="1">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Classes="step-badge">
                                    <avalonia:MaterialIcon Kind="Settings"
                                                           Width="16"
                                                           Height="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{I18N {x:Static resources:LangKeys.WizardBasicTitle}}"
                                           Classes="step-nav-title" />
                            </Grid>
                        </Button>
                        <Border Classes="step-nav-active" IsVisible="{Binding ShowBasicStep}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Classes="step-badge step-badge-active">
                                    <avalonia:MaterialIcon Kind="Settings"
                                                           Width="16"
                                                           Height="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{I18N {x:Static resources:LangKeys.WizardBasicTitle}}"
                                           Classes="step-nav-title" />
                            </Grid>
                        </Border>

                        <Button Classes="step-nav"
                                IsVisible="{Binding !ShowCloudlogStep}"
                                IsEnabled="{Binding CanNavigateToCloudlogStep}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="2">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Classes="step-badge">
                                    <avalonia:MaterialIcon Kind="CloudUpload"
                                                           Width="16"
                                                           Height="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{I18N {x:Static resources:LangKeys.WizardCloudlogTitle}}"
                                           Classes="step-nav-title" />
                            </Grid>
                        </Button>
                        <Border Classes="step-nav-active" IsVisible="{Binding ShowCloudlogStep}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Classes="step-badge step-badge-active">
                                    <avalonia:MaterialIcon Kind="CloudUpload"
                                                           Width="16"
                                                           Height="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{I18N {x:Static resources:LangKeys.WizardCloudlogTitle}}"
                                           Classes="step-nav-title" />
                            </Grid>
                        </Border>

                        <Button Classes="step-nav"
                                IsVisible="{Binding !ShowThirdPartyStep}"
                                IsEnabled="{Binding CanNavigateToThirdPartyStep}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="3">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Classes="step-badge">
                                    <avalonia:MaterialIcon Kind="FileUploadOutline"
                                                           Width="16"
                                                           Height="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{I18N {x:Static resources:LangKeys.WizardThirdPartyTitle}}"
                                           Classes="step-nav-title" />
                            </Grid>
                        </Button>
                        <Border Classes="step-nav-active" IsVisible="{Binding ShowThirdPartyStep}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Classes="step-badge step-badge-active">
                                    <avalonia:MaterialIcon Kind="FileUploadOutline"
                                                           Width="16"
                                                           Height="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{I18N {x:Static resources:LangKeys.WizardThirdPartyTitle}}"
                                           Classes="step-nav-title" />
                            </Grid>
                        </Border>

                        <Button Classes="step-nav"
                                IsVisible="{Binding !ShowRigBackendStep}"
                                IsEnabled="{Binding CanNavigateToRigBackendStep}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="4">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Classes="step-badge">
                                    <avalonia:MaterialIcon Kind="Radio"
                                                           Width="16"
                                                           Height="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{I18N {x:Static resources:LangKeys.WizardRigTitle}}"
                                           Classes="step-nav-title" />
                            </Grid>
                        </Button>
                        <Border Classes="step-nav-active" IsVisible="{Binding ShowRigBackendStep}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Classes="step-badge step-badge-active">
                                    <avalonia:MaterialIcon Kind="Radio"
                                                           Width="16"
                                                           Height="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{I18N {x:Static resources:LangKeys.WizardRigTitle}}"
                                           Classes="step-nav-title" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Button Grid.Row="1"
                        Classes="footer-link"
                        Command="{Binding OpenGithubProfileCommand}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="10 0 0 10">
                    <avalonia:MaterialIcon Kind="MicrosoftGithub"
                                           Width="22"
                                           Height="22" />
                </Button>
            </Grid>

            <Border Grid.Column="1" Classes="content-card">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="22">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <StackPanel Spacing="3">
                            <TextBlock Text="{Binding CurrentStepTitle}"
                                       Classes="content-title" />
                        </StackPanel>

                        <Border Grid.Column="1" Classes="step-count-chip" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StepIndicatorText}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0 2 6 2">
                        <ContentControl Content="{Binding CurrentStep}">
                            <ContentControl.DataTemplates>
                                <DataTemplate DataType="stepVm:WelcomeWizardStepViewModel">
                                    <stepViews:WelcomeWizardStepView />
                                </DataTemplate>
                                <DataTemplate DataType="stepVm:BasicWizardStepViewModel">
                                    <stepViews:BasicWizardStepView />
                                </DataTemplate>
                                <DataTemplate DataType="stepVm:CloudlogWizardStepViewModel">
                                    <stepViews:CloudlogWizardStepView />
                                </DataTemplate>
                                <DataTemplate DataType="stepVm:ThirdPartyWizardStepViewModel">
                                    <stepViews:ThirdPartyWizardStepView />
                                </DataTemplate>
                                <DataTemplate DataType="stepVm:RigBackendWizardStepViewModel">
                                    <stepViews:RigBackendWizardStepView />
                                </DataTemplate>
                            </ContentControl.DataTemplates>
                        </ContentControl>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Padding="0 16 0 0"
                            BorderBrush="{DynamicResource SystemControlForegroundChromeDisabledLowBrush}"
                            BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="10">
                            <Button Content="{I18N {x:Static resources:LangKeys.WizardSkip}}"
                                    HorizontalContentAlignment="Center"
                                    IsVisible="{Binding ShowSkipButton}"
                                    Command="{Binding SkipWizardCommand}"
                                    Classes="nav-secondary" />
                            <Button Content="{I18N {x:Static resources:LangKeys.WizardPrevious}}"
                                    HorizontalContentAlignment="Center"
                                    IsVisible="{Binding ShowPreviousButton}"
                                    Command="{Binding PreviousCommand}"
                                    Classes="nav-secondary" />
                            <Button Content="{I18N {x:Static resources:LangKeys.WizardNext}}"
                                    HorizontalContentAlignment="Center"
                                    IsVisible="{Binding ShowNextButton}"
                                    Command="{Binding NextCommand}"
                                    Classes="nav-primary" />
                            <Button Content="{I18N {x:Static resources:LangKeys.WizardFinish}}"
                                    HorizontalContentAlignment="Center"
                                    IsVisible="{Binding ShowFinishButton}"
                                    Command="{Binding FinishCommand}"
                                    Classes="nav-primary" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>