<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resources="clr-namespace:CloudlogHelper.Resources"
        Title="{I18N {x:Static resources:LangKeys.ErrorOccurred}}"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Width="720" Height="520"
        MinWidth="620" MinHeight="420"
        CanResize="True"
        xmlns:viewModels="clr-namespace:CloudlogHelper.ViewModels"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:DataType="viewModels:ErrorReportWindowViewModel"
        x:Class="CloudlogHelper.Views.ErrorReportWindow">
    <Design.DataContext>
        <viewModels:ErrorReportWindowViewModel />
    </Design.DataContext>
    <Grid Margin="20"
          ColumnDefinitions="Auto,*"
          RowDefinitions="Auto,Auto,*,Auto"
          ColumnSpacing="18"
          RowSpacing="14">
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                Width="96" Height="96" CornerRadius="48"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <avalonia:MaterialIcon Kind="WarningCircleOutline"
                                   Height="56" Width="56"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundAccentBrush}" />
        </Border>

        <TextBlock Grid.Row="0" Grid.Column="1"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Text="{I18N {x:Static resources:LangKeys.ErrorOccurred}}" />

        <TextBlock Grid.Row="1" Grid.Column="1"
                   FontSize="16"
                   TextWrapping="Wrap"
                   Text="{I18N {x:Static resources:LangKeys.HelpFeedback}}" />

        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                CornerRadius="8"
                Padding="12"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{DynamicResource SystemControlBackgroundChromeHighBrush}"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <SelectableTextBlock Name="ErrBlock"
                                     Text="(logs here)"
                                     TextWrapping="Wrap"
                                     Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="12">
            <Button Content="{I18N {x:Static resources:LangKeys.SaveLog}}"
                    HorizontalContentAlignment="Center"
                    MinWidth="100"
                    Click="LogSaveButton_OnClick" />
            <Button Content="{I18N {x:Static resources:LangKeys.Close}}"
                    HorizontalContentAlignment="Center"
                    MinWidth="100"
                    Click="ExitWindowButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
