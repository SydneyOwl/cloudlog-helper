<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:p="clr-namespace:CloudlogHelper.Resources.Language"
             xmlns:stepVm="clr-namespace:CloudlogHelper.ViewModels.WizardSteps"
             xmlns:userControls="clr-namespace:CloudlogHelper.Views.UserControls"
             mc:Ignorable="d"
             x:Class="CloudlogHelper.Views.WizardSteps.ThirdPartyWizardStepView"
             x:DataType="stepVm:ThirdPartyWizardStepViewModel">
    <StackPanel Spacing="14">
        <Border Classes="highlight-card" Padding="16">
            <TextBlock Text="{x:Static p:Language.WizardThirdPartyHint}"
                       Classes="page-hint" />
        </Border>
        <userControls:LogSystemCard
            DataContext="{Binding LogSystemCard}" />
    </StackPanel>
</UserControl>
